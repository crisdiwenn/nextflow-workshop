/*
 * Nextflow config for Exercise 02
 *
 * Profiles let you switch container runtimes without changing the pipeline.
 * On Linux/WSL2:  -profile apptainer
 * On macOS:       -profile docker
 */

profiles {
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = "${HOME}/.apptainer/cache"
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
}

// Default resource requests. Small enough to run on any laptop.
process {
    cpus = 2
    memory = '2 GB'

    // Per-process overrides go here if needed:
    // withName: FASTQC {
    //     cpus = 4
    // }
}

// Make the pipeline output a nice HTML report after each run
report {
    enabled = true
    file = "results/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "results/pipeline_timeline.html"
    overwrite = true
}
