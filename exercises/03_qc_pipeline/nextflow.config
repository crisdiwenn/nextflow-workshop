/*
 * Nextflow config for Exercise 03 — QC Pipeline
 */

profiles {
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = "${HOME}/.apptainer/cache"
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    // Bonus profile for HPC users — try this on a SLURM cluster
    slurm {
        apptainer.enabled = true
        apptainer.autoMounts = true
        process {
            executor = 'slurm'
            queue    = 'vera'
            clusterOptions = '-A YOUR_PROJECT_ID'
        }
    }
}

process {
    cpus = 2
    memory = '2 GB'

    // FASTP is slightly heavier than the others
    withName: FASTP {
        cpus = 4
        memory = '4 GB'
    }
}

report {
    enabled = true
    file = "results/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "results/pipeline_timeline.html"
    overwrite = true
}

dag {
    enabled = true
    file = "results/pipeline_dag.html"
    overwrite = true
}
